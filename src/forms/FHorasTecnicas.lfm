      Height = 24
      Style = csDropDownList
      TabOrder = 2
    end
    object BtnIniciar: TButton
      Left = 8
      Top = 64
      Width = 90
      Height = 28
      Caption = '▶ Iniciar'
      OnClick = BtnIniciarClick
      TabOrder = 3
    end
    object BtnParar: TButton
      Left = 104
      Top = 64
      Width = 90
      Height = 28
      Caption = '■ Parar'
      Enabled = False
      OnClick = BtnPararClick
      TabOrder = 4
    end
    object LblTempo: TLabel
      Left = 212
      Top = 68
      Width = 60
      Height = 20
      Caption = '00:00'
      Font.Height = -16
      Font.Style = [fsBold]
      ParentFont = False
    end
    object TimerTick: TTimer
      Enabled = False
      Interval = 1000
      OnTimer = TimerTickTimer
      Left = 700
      Top = 60
    end
  end
  object PnlLog: TPanel
    Left = 0
    Top = 100
    Width = 800
    Height = 280
    Align = alClient
    BevelOuter = bvNone
    TabOrder = 1
    object SgHoras: TStringGrid
