object FormHorasTecnicas: TFormHorasTecnicas
  Left = 0
  Top = 0
  Width = 800
  Height = 580
  Caption = 'Horas Técnicas'
  Color = clBtnFace
  Font.Charset = DEFAULT_CHARSET
  Font.Color = clWindowText
  Font.Height = -13
  Font.Name = 'Segoe UI'
  Font.Style = []
  OnCreate = FormCreate
  OnDestroy = FormDestroy
  PixelsPerInch = 96
  TextHeight = 16
  object PnlTimer: TPanel
    Left = 0
    Top = 0
    Width = 800
    Height = 100
    Align = alTop
    BevelOuter = bvNone
    Color = clWhite
    TabOrder = 0
    object LblMembro: TLabel
      Left = 8
      Top = 8
      Width = 54
      Height = 16
      Caption = 'Membro:'
    end
    object CmbMembro: TComboBox
      Left = 8
      Top = 28
      Width = 180
      Height = 24
      Style = csDropDownList
      OnChange = CmbMembroChange
      TabOrder = 0
    end
    object LblTarefa: TLabel
      Left = 200
      Top = 8
      Width = 47
      Height = 16
      Caption = 'Tarefa:'
    end
    object CmbTarefa: TComboBox
      Left = 200
      Top = 28
      Width = 280
      Height = 24
      Style = csDropDownList
